{
  "name": "isskinui",
  "version": "1.6.6",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/main.js",
    "./icons": "./dist/icons/index.js",
    "./components": "./dist/components/index.js",
    "./css": "./dist/assets/main.css"
  },
  "scripts": {
    "dev": "cd playground && vite",
    "build:tokens": "style-dictionary build --config lib/style-dictionary.config.js",
    "build": "npm run build:tokens && tsx lib/scripts/buildNestedTokens.ts && tsc --p ./tsconfig.lib.json && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview --config playground/vite.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": [
    "**/*.css",
    "./lib/styles/theme.css",
    "./lib/styles/fonts.css"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.1",
    "@eslint/js": "^9.29.0",
    "@storybook/addon-a11y": "^9.0.14",
    "@storybook/addon-docs": "^9.0.14",
    "@storybook/addon-onboarding": "^9.0.14",
    "@storybook/addon-vitest": "^9.0.14",
    "@storybook/builder-vite": "^9.0.14",
    "@storybook/react": "^9.0.14",
    "@storybook/react-vite": "^9.0.14",
    "@storybook/testing-library": "^0.2.1",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vanilla-extract/vite-plugin": "^5.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.29.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-regexp": "^2.9.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^9.0.14",
    "glob": "^11.0.3",
    "globals": "^16.2.0",
    "playwright": "^1.53.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rollup-plugin-copy": "^3.5.0",
    "storybook": "^9.0.14",
    "style-dictionary": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vite-plugin-static-copy": "^3.1.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@babel/core": "^7.27.7",
    "@svgr/core": "^6.5.1",
    "@svgr/plugin-jsx": "^6.5.1",
    "@svgr/plugin-svgo": "^8.1.0",
    "isskinui": "^1.6.1",
    "prettier": "^3.6.2",
    "radix-ui": "^1.4.2",
    "react-datepicker": "^8.4.0",
    "rollup-plugin-visualizer": "^6.0.3",
    "zustand": "^5.0.6"
  }
}
